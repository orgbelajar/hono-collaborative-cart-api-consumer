generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model authentications {
  token String @id
}

model cart_activities {
  id          String   @id @db.VarChar(50)
  cartId      String   @db.VarChar(50)
  productId   String   @db.VarChar(50)
  userId      String   @db.VarChar(50)
  action      String   @db.VarChar(50)
  time        DateTime @default(now()) @db.Timestamptz(6)
  productName String   @db.VarChar(100)
  username    String   @db.VarChar(50)
  qty         Int      @default(1)
  carts       carts    @relation(fields: [cartId], references: [id], onDelete: Cascade)
}

model cart_items {
  id        String   @id @db.VarChar(50)
  cartId    String   @db.VarChar(50)
  productId String   @db.VarChar(50)
  qty       Int
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  updatedAt DateTime @db.Timestamptz(6)
  carts     carts    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  products  products @relation(fields: [productId], references: [id], onDelete: Cascade)
}

model cart_shared_users {
  id        String   @id @db.VarChar(50)
  cartId    String   @db.VarChar(50)
  userId    String   @db.VarChar(50)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  carts     carts    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([cartId, userId])
}

model carts {
  id                String              @id @db.VarChar(50)
  name              String              @db.VarChar(100)
  ownerId           String              @db.VarChar(50)
  createdAt         DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime            @db.Timestamptz(6)
  cart_activities   cart_activities[]
  cart_items        cart_items[]
  cart_shared_users cart_shared_users[]
  users             users               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
}

model categories {
  id        String     @id @db.VarChar(50)
  name      String     @db.VarChar(100)
  createdAt DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt DateTime   @db.Timestamptz(6)
  slug      String     @unique @db.VarChar(180)
  products  products[]
}

model products {
  id          String       @id @db.VarChar(50)
  name        String       @db.VarChar(150)
  description String?
  price       Int
  stock       Int
  categoryId  String       @db.VarChar(50)
  createdAt   DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt   DateTime     @db.Timestamptz(6)
  image       String?
  cart_items  cart_items[]
  categories  categories   @relation(fields: [categoryId], references: [id])
  wishlists   wishlists[]
}

model users {
  id                String              @id @db.VarChar(50)
  username          String              @unique @db.VarChar(50)
  password          String
  fullname          String              @db.VarChar(100)
  createdAt         DateTime            @default(now()) @db.Timestamptz(6)
  updatedAt         DateTime            @db.Timestamptz(6)
  cart_shared_users cart_shared_users[]
  carts             carts[]
  wishlists         wishlists[]
}

model wishlists {
  id        String   @id @db.VarChar(50)
  userId    String   @db.VarChar(50)
  productId String   @db.VarChar(50)
  createdAt DateTime @default(now()) @db.Timestamptz(6)
  products  products @relation(fields: [productId], references: [id], onDelete: Cascade)
  users     users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
}
